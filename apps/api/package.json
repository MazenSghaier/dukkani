{
	"name": "@dukkani/api",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --port=3002",
		"build": "pnpm --filter @dukkani/db run db:migrate:deploy && (test \"$VERCEL_ENV\" != \"preview\" || pnpm --filter @dukkani/db run db:seed) && next build",
		"start": "next start",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"check-types:fast": "tsgo --noEmit -p tsconfig.json",
		"clean": "rm -rf .next node_modules"
	},
	"dependencies": {
		"@dukkani/auth": "workspace:*",
		"@dukkani/common": "workspace:*",
		"@dukkani/core": "workspace:*",
		"@dukkani/db": "workspace:*",
		"@dukkani/env": "workspace:*",
		"@dukkani/logger": "workspace:*",
		"@dukkani/orpc": "workspace:*",
		"@dukkani/tracing": "workspace:*",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@prisma/client": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"next": "catalog:",
		"pg": "^8.16.3",
		"sharp": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@dukkani/config": "workspace:*",
		"@t3-oss/env-nextjs": "catalog:",
		"@types/node": "catalog:",
		"baseline-browser-mapping": "catalog:",
		"typescript": "catalog:"
	}
}
