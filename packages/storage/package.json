{
	"name": "@dukkani/storage",
	"version": "0.1.0",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./env": {
			"types": "./dist/env.d.ts",
			"default": "./src/env.ts"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./src/*.ts"
		}
	},
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"check-types:fast": "tsgo --noEmit -p tsconfig.json",
		"clean": "rm -rf dist node_modules"
	},
	"devDependencies": {
		"@dukkani/config": "workspace:*",
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@dukkani/db": "workspace:*",
		"@dukkani/env": "workspace:*",
		"@dukkani/common": "workspace:*",
		"@dukkani/logger": "workspace:*",
		"@dukkani/tracing": "workspace:*",
		"@aws-sdk/client-s3": "catalog:",
		"sharp": "catalog:",
		"nanoid": "catalog:"
	}
}
