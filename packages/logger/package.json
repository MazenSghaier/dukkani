{
	"name": "@dukkani/logger",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit -p tsconfig.json",
