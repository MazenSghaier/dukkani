{
	"name": "@dukkani/env",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"check-types:fast": "tsgo --noEmit -p tsconfig.json",
		"clean": "rm -rf dist node_modules"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./presets": {
			"types": "./src/presets/index.ts",
			"default": "./src/presets/index.ts"
		},
		"./base": {
			"types": "./src/base.ts",
			"default": "./src/base.ts"
		},
		"./presets/ci-tools": {
			"types": "./src/presets/ci-tools.ts",
			"default": "./src/presets/ci-tools.ts"
		},
		"./presets/api": {
			"types": "./src/presets/api.ts",
			"default": "./src/presets/api.ts"
		},
		"./presets/dashboard": {
			"types": "./src/presets/dashboard.ts",
			"default": "./src/presets/dashboard.ts"
		},
		"./presets/db": {
			"types": "./src/presets/db.ts",
			"default": "./src/presets/db.ts"
		},
		"./presets/web": {
			"types": "./src/presets/web.ts",
			"default": "./src/presets/web.ts"
		},
		"./presets/storefront": {
			"types": "./src/presets/storefront.ts",
			"default": "./src/presets/storefront.ts"
		},
		"./get-api-url": {
			"types": "./src/utils/get-api-url.ts",
			"default": "./src/utils/get-api-url.ts"
		},
		"./get-storefront-base-url": {
			"types": "./src/utils/get-storefront-base-url.ts",
			"default": "./src/utils/get-storefront-base-url.ts"
		},
		"./modules": {
			"types": "./src/modules/index.ts",
			"default": "./src/modules/index.ts"
		}
	},
	"dependencies": {
		"@vercel/related-projects": "catalog:",
		"@t3-oss/env-core": "catalog:",
		"@t3-oss/env-nextjs": "catalog:",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@dukkani/config": "workspace:*"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	}
}
