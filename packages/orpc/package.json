{
	"name": "@dukkani/orpc",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"default": "./src/client.ts"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./src/*.ts"
		},
		"./routers": {
			"types": "./dist/routers.d.ts",
			"default": "./src/routers/index.ts"
		}
	},
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"check-types:fast": "tsgo --noEmit -p tsconfig.json",
		"clean": "rm -rf dist node_modules"
	},
	"devDependencies": {
		"@dukkani/config": "workspace:*",
		"next": "catalog:",
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"typescript": "^6.0.2",
		"next": ">=14.0.0"
	},
	"dependencies": {
		"@dukkani/auth": "workspace:*",
		"@dukkani/tracing": "workspace:*",
		"@dukkani/logger": "workspace:*",
		"@dukkani/common": "workspace:*",
		"@dukkani/db": "workspace:*",
		"@dukkani/core": "workspace:*",
		"@dukkani/storage": "workspace:*",
		"@dukkani/env": "workspace:*",
		"@orpc/client": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/tanstack-query": "catalog:",
		"@prisma/client": "catalog:",
		"@tanstack/react-query": "catalog:",
		"dotenv": "catalog:",
		"sonner": "catalog:",
		"zod": "catalog:",
		"@opentelemetry/api": "^1.9.0"
	}
}
